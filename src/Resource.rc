            VALUE "OriginalFilename", "HDRViewer.exe"
            VALUE "ProductName",      "HDRViewer"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 0x04B0
    END
END

// 应用清单 — DPI 感知 + Win10 兼容
1 RT_MANIFEST "app.manifest"
